{
  "name": "ai-agent-framework",
  "version": "1.0.0",
  "description": "Lightweight TypeScript framework for building AI agents with tool use, memory, and execution tracing",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "dev": "tsx examples/weather-agent.ts",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "example": "tsx examples/weather-agent.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai-agent",
    "llm",
    "react-agent",
    "tool-use",
    "function-calling",
    "typescript",
    "openai"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "openai": "^4.73.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
